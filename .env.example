# MeuPluggy (gratis) — credenciais do dashboard.pluggy.ai
PLUGGY_CLIENT_ID=seu_client_id
PLUGGY_CLIENT_SECRET=seu_client_secret

# IDs dos itens (separados por virgula) — um por banco conectado no MeuPluggy
# Passos: meu.pluggy.ai → conectar banco → dashboard.pluggy.ai → Demo App → autorizar → copiar itemId
# Ex: PLUGGY_ITEM_IDS=abc123,def456,ghi789
PLUGGY_ITEM_IDS=

# Banco de dados
DATABASE_URL="file:./dev.db"

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Porta
PORT=3001
